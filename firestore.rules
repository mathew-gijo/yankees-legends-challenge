rules_version = '2';

// Security rules for Yankees Legends Challenge.
// Paste these into the Firebase console → Firestore Database → Rules → Publish.
// (Or deploy with the Firebase CLI: `firebase deploy --only firestore:rules`.)
//
// The app signs every player in with anonymous auth, so requiring
// `request.auth != null` keeps out unauthenticated traffic while still letting
// any guest join a room. Everything outside the `games` collection is denied.
service cloud.firestore {
  match /databases/{database}/documents {

    match /games/{code} {
      allow read, write: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
